# ═══════════════════════════════════════════════════════════════
# BACHAO — Flood Intelligence System
# Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ─── SERVER ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── DATABASE ────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/bachao

# ─── WHATSAPP INTEGRATION ────────────────────────────────────────
# Get these from Meta/Facebook Business Dashboard
# https://www.facebook.com/developer

# WhatsApp Business Account Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# WhatsApp Business Account Access Token
WHATSAPP_TOKEN=your_access_token_here

# Webhook verification token (create your own random string)
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token_here

# ─── DEPRECATED (NO LONGER USED) ─────────────────────────────────
# Twilio is NOT available in Pakistan - alerts use WhatsApp only
# TWILIO_ACCOUNT_SID=xxx
# TWILIO_AUTH_TOKEN=xxx
# TWILIO_FROM_NUMBER=xxx

# ─── OPTIONAL ────────────────────────────────────────────────────
# For satellite data and other services
LOG_LEVEL=info
